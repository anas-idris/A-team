---
import BaseLayout from '../components/Layout/BaseLayout.astro';
import Header from '../components/Layout/Header.astro';
import Footer from '../components/Layout/Footer.astro';
import Skills from '../components/Pages/Skills.astro';
import SocialIcons from '../components/Pages/SocialIcons.astro';
import PageHeader from '../components/Pages/PageHeader.astro';
import { socialLinks, skills, aboutMe, quickLinks } from '../lib';
---

<BaseLayout title="Home" description="Anas \u2014 Project/Product Manager Portfolio">
  <Header />
  
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center pt-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <h1 class="text-4xl md:text-5xl font-bold text-professional-primary mb-4">{aboutMe.intro}</h1>
          <p class="text-xl text-professional-accent mb-6 font-medium">{aboutMe.role}</p>
          <p class="text-lg text-professional-text-secondary leading-relaxed mb-8">
            {aboutMe.summary}
          </p>
          
          <!-- Skills -->
          <Skills socialLinks={skills} />
          
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="#about" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-professional-accent text-white font-medium hover:bg-professional-accent-dark transition-colors">
              Learn More
            </a>
            <a href="/work-projects" class="inline-flex items-center justify-center px-6 py-3 rounded-md border-2 border-professional-accent text-professional-accent font-medium hover:bg-professional-accent hover:text-white transition-colors">
              View Work
            </a>
          </div>
        </div>
        
        <div class="flex justify-center order-1 md:order-2">
          <img
            src="/images/profile.jpg"
            alt="Anas Idris"
            class="w-64 h-64 rounded-full object-cover border-4 border-professional-accent/30 shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>
  
  <!-- About Section -->
  <section id="about" class="py-24 bg-professional-alt-background">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <div>
            <h3 class="text-xl font-semibold text-professional-primary mb-4">Who I Am</h3>
            <p class="text-professional-text-secondary leading-relaxed mb-4">
              {aboutMe.whoIAm}
            </p>
          </div>
          
          <div>
            <h3 class="text-xl font-semibold text-professional-primary mb-4">What I Bring</h3>
            <ul class="space-y-3 text-professional-text-secondary">
              {aboutMe.whatIBring.map(item => (
                <li class="flex items-start gap-2">
                  <svg class="w-5 h-5 text-professional-accent mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <!-- Quick Links -->
  <section class="py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {quickLinks.map(link => (
          <a href={link.href} class="block bg-professional-surface rounded-lg shadow-sm hover:shadow-lg transition-all duration-300 p-8 border border-professional-border hover:border-professional-accent">
            <div class="w-12 h-12 rounded-lg bg-professional-accent/10 flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-professional-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                {link.title === 'Work Projects' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />}
                {link.title === 'Self Projects' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />}
                {link.title === 'Get In Touch' && <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />}
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-professional-primary mb-2">{link.title}</h3>
            <p class="text-professional-text-secondary">{link.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  
  <Footer socialLinks={socialLinks} />
</BaseLayout>
