---
import BaseLayout from '../../components/Layout/BaseLayout.astro';
import Header from '../../components/Layout/Header.astro';
import Footer from '../../components/Layout/Footer.astro';
import PageHeader from '../../components/Pages/PageHeader.astro';
import SelfProjectCard from '../../components/Pages/SelfProjectCard.astro';
import { socialLinks } from '../../lib';
import { getSelfProjects } from '../../lib/services/projectService';

const projects = getSelfProjects();
---

<BaseLayout title="Self Projects" description="Personal projects and applications by Anas Idris">
  <Header />
  
  <section class="pt-32 pb-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <PageHeader title="Self Projects" description="Personal projects and applications I've built from concept to deployment." />
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
        {projects.map(project => (
          <SelfProjectCard project={project} />
        ))}
      </div>
    </div>
  </section>
  
  <Footer socialLinks={socialLinks} />
</BaseLayout>
