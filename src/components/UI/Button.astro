---
interface ButtonProps {
  text: string;
  link: string;
  variant?: 'primary' | 'secondary';
  eventAction?: string;
}

const { text, link, variant = 'primary', eventAction } = Astro.props;

const btnClass = variant === 'primary'
  ? 'inline-flex items-center justify-center px-6 py-3 text-white bg-white/10 hover:bg-white/20 transition-colors text-sm rounded'
  : 'inline-flex items-center justify-center px-6 py-3 text-white border border-[#333] hover:border-white transition-colors text-sm rounded';
---

{eventAction ? (
  <a href={link} class={btnClass} aria-label={text} onclick={(e) => {
    if (typeof window !== 'undefined' && window.plausible) {
      window.plausible('cta_click', { props: { action: eventAction } });
    }
  }}>{text}</a>
) : (
  <a href={link} class={btnClass} aria-label={text}>{text}</a>
)}
