---
import type { SocialLink, ContactInfo } from '../../lib';
import SocialIcons from './SocialIcons.astro';

interface Props {
  socialLinks: SocialLink[];
  contactInfo: ContactInfo;
}

const { socialLinks, contactInfo } = Astro.props;
---

<div class="bg-professional-surface rounded-lg shadow-sm p-8 border border-professional-border">
  <h3 class="text-xl font-semibold text-professional-primary mb-6">Contact Information</h3>
  <div class="space-y-6">
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-lg bg-professional-accent/10 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-professional-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-professional-text-disabled mb-1">Email</p>
        <a href={`mailto:${contactInfo.email}`} class="text-professional-text-primary hover:text-professional-accent transition-colors">{contactInfo.email}</a>
      </div>
    </div>
    
    {contactInfo.phone && (
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-lg bg-professional-accent/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5 text-professional-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-professional-text-disabled mb-1">Phone</p>
          <a href={`tel:${contactInfo.phone}`} class="text-professional-text-primary hover:text-professional-accent transition-colors">{contactInfo.phone}</a>
        </div>
      </div>
    )}
    
    <div class="flex items-start gap-4">
      <div class="w-10 h-10 rounded-lg bg-professional-accent/10 flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-professional-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
      </div>
      <div>
        <p class="text-sm text-professional-text-disabled mb-1">Location</p>
        <p class="text-professional-text-primary">Available Worldwide (Remote)</p>
      </div>
    </div>
  </div>
  
  <!-- Social Links -->
  <div class="mt-10 pt-6 border-t border-professional-border">
    <p class="text-sm text-professional-text-disabled mb-4">Connect</p>
    <div class="flex gap-4">
      <SocialIcons socialLinks={socialLinks} />
    </div>
  </div>
</div>
