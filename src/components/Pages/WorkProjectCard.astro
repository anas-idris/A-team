---
import type { WorkProject } from '../../lib';

interface Props {
  project: WorkProject;
}

const { project } = Astro.props;
---

<a
  href={project.link}
  target="_blank"
  rel="noopener noreferrer"
  class="block bg-professional-surface rounded-lg shadow-sm hover:shadow-xl transition-all duration-300 overflow-hidden border border-professional-border hover:border-professional-accent group"
>
  <div class="h-2 bg-gradient-to-r from-professional-accent to-brand-primary"></div>
  <div class="p-6">
    <div class="flex items-start justify-between mb-3">
      <span class="px-3 py-1 rounded-full text-xs font-medium bg-professional-accent/10 text-professional-accent">{project.category}</span>
      <span class="text-xs text-professional-text-disabled font-mono">{project.year}</span>
    </div>
    <h3 class="text-lg font-semibold text-professional-primary mb-2 group-hover:text-professional-accent transition-colors">{project.title}</h3>
    <p class="text-sm text-professional-text-secondary mb-4 line-clamp-2">{project.description}</p>
    <div class="flex flex-wrap gap-2">
      {project.tags.map(tag => (
        <span class="px-2 py-1 rounded text-xs bg-professional-alt-background text-professional-text-secondary">{tag}</span>
      ))}
    </div>
    <div class="mt-4 pt-4 border-t border-professional-border flex items-center text-professional-accent text-sm font-medium group-hover:translate-x-2 transition-transform">
      View Project
      <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
