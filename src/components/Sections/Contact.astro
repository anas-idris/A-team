---
interface ContactProps {
  contactInfo: {
    email: string;
    phone: string;
  };
  socialLinks?: Array<{
    platform: string;
    url: string;
    icon: 'linkedin' | 'github' | 'twitter';
  }>;
}

const { contactInfo = { email: 'bisquery@gmail.com', phone: '' }, socialLinks } = Astro.props;

function validateEmail(email: string): boolean {
  const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return re.test(email);
}
---

<div class="bg-[#0a0a0a] py-24">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 max-w-4xl mx-auto">
      <!-- Contact Info -->
      <div>
        <h3 class="text-white text-lg mb-6">Contact</h3>
        <div class="space-y-6">
          <div>
            <p class="text-gray-600 text-xs font-mono mb-2">Email</p>
            <a href={`mailto:${contactInfo.email}`} class="text-white text-sm hover:text-gray-300 transition-colors">{contactInfo.email}</a>
          </div>
          
          {contactInfo.phone && (
            <div>
              <p class="text-gray-600 text-xs font-mono mb-2">Phone</p>
              <a href={`tel:${contactInfo.phone}`} class="text-white text-sm hover:text-gray-300 transition-colors">{contactInfo.phone}</a>
            </div>
          )}
          
          <div>
            <p class="text-gray-600 text-xs font-mono mb-2">Location</p>
            <p class="text-white text-sm">Available Worldwide (Remote)</p>
          </div>
        </div>
        
        <!-- Social Links -->
        <div class="mt-10 pt-6 border-t border-[#1a1a1a]">
          <p class="text-gray-600 text-xs font-mono mb-4">Connect</p>
          <div class="flex gap-6">
            {socialLinks.map(link => (
              <a
                href={link.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-500 hover:text-white transition-colors duration-200 text-sm"
                aria-label={link.platform}
              >
                {link.platform}
              </a>
            ))}
          </div>
        </div>
      </div>
      
      <!-- Contact Form -->
      <div>
        <form id="contact-form" class="space-y-5" action="/" method="POST" netlify name="contact">
          <input type="hidden" name="form-name" value="contact" />
          
          <p class="hidden">
            <label>Don't fill this out: <input name="website" tabindex="-1" autocomplete="off" /></label>
          </p>
          
          <div>
            <label for="name" class="block text-xs font-mono text-gray-600 mb-2">Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name" class="w-full px-0 py-2 bg-transparent border-b border-[#222] text-white text-sm focus:border-white focus:outline-none transition-colors" />
          </div>
          
          <div>
            <label for="email" class="block text-xs font-mono text-gray-600 mb-2">Email</label>
            <input type="email" id="email" name="email" required placeholder="your@email.com" class="w-full px-0 py-2 bg-transparent border-b border-[#222] text-white text-sm focus:border-white focus:outline-none transition-colors" />
          </div>
          
          <div>
            <label for="subject" class="block text-xs font-mono text-gray-600 mb-2">Subject</label>
            <input type="text" id="subject" name="subject" required placeholder="Subject" class="w-full px-0 py-2 bg-transparent border-b border-[#222] text-white text-sm focus:border-white focus:outline-none transition-colors" />
          </div>
          
          <div>
            <label for="message" class="block text-xs font-mono text-gray-600 mb-2">Message</label>
            <textarea id="message" name="message" required rows="4" placeholder="Your message" maxlength="500" class="w-full px-0 py-2 bg-transparent border-b border-[#222] text-white text-sm focus:border-white focus:outline-none transition-colors resize-none"></textarea>
            <div class="flex justify-between mt-1">
              <p id="message-error" class="text-xs text-red-500 hidden" role="alert"></p>
              <p id="char-count" class="text-xs text-gray-600 font-mono ml-auto" aria-live="polite">0 / 500</p>
            </div>
          </div>
          
          <button type="submit" id="submit-btn" class="w-full px-6 py-3 bg-white/10 text-white text-sm hover:bg-white/20 transition-colors rounded flex items-center justify-center gap-2">
            <span class="btn-text">Send Message</span>
            <svg id="submit-spinner" class="animate-spin h-4 w-4 text-white hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
          </button>
        </form>
        
        <div id="success-message" class="hidden mt-4 p-4 rounded bg-white/5 border border-white/10">
          <div class="flex items-center gap-3">
            <p class="text-white text-sm">Message sent! I'll get back to you soon.</p>
          </div>
        </div>
        
        <div id="error-message" class="hidden mt-4 p-4 rounded bg-red-500/10 border border-red-500/20">
          <div class="flex items-center gap-3">
            <p class="text-red-500 text-sm">Something went wrong. Please try again.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script client:load>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const spinner = document.getElementById('submit-spinner');
  const btnText = document.querySelector('.btn-text');
  const successMsg = document.getElementById('success-message');
  const errorMsg = document.getElementById('error-message');
  const charCount = document.getElementById('char-count');
  const messageInput = document.getElementById('message');

  messageInput?.addEventListener('input', () => {
    const count = messageInput.value.length;
    charCount.textContent = `${count} / 500`;
    if (count > 450) {
      charCount.className = 'text-xs text-red-500 font-mono ml-auto';
    } else {
      charCount.className = 'text-xs text-gray-600 font-mono ml-auto';
    }
  });

  function validateEmail(email) {
    const re = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return re.test(email);
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    let isValid = true;
    const nameInput = document.getElementById('name');
    const emailInput = document.getElementById('email');
    const subjectInput = document.getElementById('subject');
    const messageInput = document.getElementById('message');

    const validators = [
      { input: nameInput, errorId: 'name-error', message: 'Name is required' },
      { input: emailInput, errorId: 'email-error', message: 'Please enter a valid email' },
      { input: subjectInput, errorId: 'subject-error', message: 'Subject is required' },
      { input: messageInput, errorId: 'message-error', message: 'Message is required' },
    ];

    validators.forEach(({ input, errorId, message }) => {
      const errorEl = document.getElementById(errorId);
      if (!input.value.trim()) {
        if (errorEl) {
          errorEl.textContent = message;
          errorEl.classList.remove('hidden');
        }
        isValid = false;
      } else if (input.id === 'email' && !validateEmail(input.value)) {
        if (errorEl) {
          errorEl.textContent = message;
          errorEl.classList.remove('hidden');
        }
        isValid = false;
      } else if (errorEl) {
        errorEl.classList.add('hidden');
      }
    });

    if (!isValid) return;

    submitBtn.disabled = true;
    spinner.classList.remove('hidden');
    btnText.textContent = 'Sending...';

    try {
      const formData = new FormData(form);
      const response = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData),
      });

      if (response.ok) {
        successMsg.classList.remove('hidden');
        form.reset();
        charCount.textContent = '0 / 500';
        if (typeof window !== 'undefined' && window.plausible) {
          window.plausible('form_submit', { props: { section: 'contact' } });
        }
        setTimeout(() => {
          successMsg.classList.add('hidden');
        }, 5000);
      } else {
        throw new Error('Submission failed');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      spinner.classList.add('hidden');
      btnText.textContent = 'Send Message';
    }
  });
</script>
