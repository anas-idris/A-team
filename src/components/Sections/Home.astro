---
import Button from '../UI/Button.astro';
import { getAllPortfolioItems } from '../../lib/sanity';
import { getImage } from 'astro:assets';

interface HomeProps {
  developerName: string;
  bio: string;
  skills: string[];
  appInfo: {
    name: string;
    tagline: string;
    description: string;
  };
  portrait?: string;
}

const {
  developerName = 'Anas',
  bio = '',
  skills = [],
  appInfo = { name: '', tagline: '', description: '' },
  portrait,
} = Astro.props;

const portfolioItems = await getAllPortfolioItems();
---

<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
    <div class="text-center md:text-left order-2 md:order-1">
      <h1 class="font-heading text-h1 text-professional-primary mb-2">{developerName}</h1>
      <p class="text-body-large text-professional-text-secondary mb-8">Mobile Developer</p>
      <p class="text-body text-professional-text-primary max-w-lg mb-8">{bio}</p>
      
      <!-- Skills -->
      <div class="flex flex-wrap gap-3 mb-8">
        {skills.map(skill => (
          <span class="inline-block px-4 py-2 rounded-full text-body-small bg-professional-accent/10 text-professional-accent">{skill}</span>
        ))}
      </div>
      
      <!-- App Overview -->
      <div class="mt-8 mb-12 max-w-2xl">
        <div class="bg-professional-alt-background rounded-lg shadow-md p-6 flex items-start gap-4">
          <div class="w-12 h-12 rounded-lg bg-spent-primary flex items-center justify-center flex-shrink-0">
            <span class="text-2xl">💰</span>
          </div>
          <div>
            <h3 class="font-heading text-h3 text-professional-primary">{appInfo.name}</h3>
            <p class="text-professional-accent text-body-small mb-1">{appInfo.tagline}</p>
            <p class="text-body text-professional-text-primary">{appInfo.description}</p>
          </div>
        </div>
      </div>
      
      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
        <Button text="View Product" link="#product" variant="primary" eventAction="view_product" />
        <Button text="Contact Me" link="#contact" variant="secondary" eventAction="contact" />
      </div>
    </div>
    
    <!-- Portrait -->
    <div class="flex justify-center order-1 md:order-2">
      {portrait ? (() => {
        const isLocalFile = portrait.startsWith('/') && portrait.match(/\.(png|jpe?g|svg|webp|avif)$/i);
        if (isLocalFile) {
          try {
            const imageModule = require(portrait.replace('/images/', '../../public').replace(/^\//, ''));
            const optimized = getImage({ src: imageModule.default || imageModule, formats: ['webp', 'avif'], width: 256, height: 256 });
            return <img src={optimized.src} width={optimized.width} height={optimized.height} alt={`${developerName} - Mobile Developer`} class="w-48 h-48 sm:w-64 sm:h-64 rounded-full border-4 border-professional-accent/30 shadow-lg object-cover" decoding="async" />;
          } catch {
            return <img src={portrait} width={256} height={256} alt={`${developerName} - Mobile Developer`} class="w-48 h-48 sm:w-64 sm:h-64 rounded-full border-4 border-professional-accent/30 shadow-lg object-cover" loading="lazy" decoding="async" />;
          }
        }
        return <img src={portrait} width={256} height={256} alt={`${developerName} - Mobile Developer`} class="w-48 h-48 sm:w-64 sm:h-64 rounded-full border-4 border-professional-accent/30 shadow-lg object-cover" loading="lazy" decoding="async" />;
      })() : (
        <div class="w-48 h-48 sm:w-64 sm:h-64 rounded-full bg-professional-primary-light flex items-center justify-center border-4 border-professional-accent/30">
          <span class="text-6xl font-heading font-bold text-professional-primary">{developerName.charAt(0)}</span>
        </div>
      )}
    </div>
  </div>
  
  <!-- Portfolio Projects from Sanity -->
  {portfolioItems.length > 0 && (
    <div class="mt-16">
      <h3 class="font-heading text-h3 text-professional-primary text-center mb-8">Featured Projects</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {portfolioItems.map(item => (
          <a
            href={`#${item.slug.current}`}
            class="block bg-professional-surface rounded-lg shadow-sm hover:shadow-lg transition-shadow duration-300 overflow-hidden"
          >
            <img
              src={item.imageUrl.asset.url}
              alt={item.title}
              width={600}
              height={400}
              loading="lazy"
              decoding="async"
              class="w-full h-48 object-cover"
            />
            <div class="p-6">
              <h4 class="font-heading text-h4 text-professional-primary mb-2">{item.title}</h4>
              <p class="text-body text-professional-text-secondary line-clamp-2">{item.description}</p>
              {item.category && (
                <p class="text-body-small text-professional-accent mt-1">{item.category}</p>
              )}
              <div class="flex flex-wrap gap-2 mt-4">
                {item.techStack.slice(0, 3).map(tech => (
                  <span class="px-3 py-1 rounded-full text-body-small bg-professional-accent/10 text-professional-accent">{tech}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}
</div>
