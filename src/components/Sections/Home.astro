---
interface HomeProps {
  developerName: string;
  tagline: string;
  subtitle: string;
  projects: Array<{
    title: string;
    description: string;
    category: string;
    year: string;
    tags: string[];
    link?: string;
  }>;
}

const {
  developerName = 'Anas',
  tagline = '',
  subtitle = '',
  projects = [],
} = Astro.props;
---

<!-- Hero -->
<section id="home" class="min-h-screen flex flex-col justify-center px-6 md:px-8 pt-20 pb-32">
  <div class="container mx-auto">
    <h1 class="text-[clamp(2.5rem,6vw,5.5rem)] font-medium leading-[1.1] tracking-tight mb-8">
      {developerName}
    </h1>
    <p class="text-[clamp(1.1rem,2vw,1.5rem)] text-[#555] max-w-2xl leading-relaxed font-light">
      {tagline}
    </p>
    <p class="text-[clamp(0.9rem,1.5vw,1.1rem)] text-[#333] max-w-2xl leading-relaxed mt-4 font-light">
      {subtitle}
    </p>
  </div>
</section>

<!-- Projects -->
<section id="work" class="px-6 md:px-8 pb-32">
  <div class="container mx-auto">
    <div class="border-t border-[#1a1a1a]"></div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-0">
      {projects.map((project, index) => (
        <a
          href={project.link || '#'}
          class="group py-8 border-t border-[#1a1a1a] block"
        >
          <div class="flex items-start justify-between mb-3">
            <h3 class="text-white text-lg md:text-xl font-normal group-hover:text-[#888] transition-colors duration-200">{project.title}</h3>
            <span class="text-[#333] text-xs font-mono flex-shrink-0 ml-4">{project.year}</span>
          </div>
          <p class="text-[#555] text-sm leading-relaxed mb-4">{project.description}</p>
          <div class="flex flex-wrap gap-3">
            {project.tags.map(tag => (
              <span class="text-[#444] text-xs font-mono">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- About -->
<section id="about" class="px-6 md:px-8 py-32 border-t border-[#1a1a1a]">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
      <div>
        <h2 class="text-[#333] text-xs font-mono uppercase tracking-widest mb-8">About</h2>
        <p class="text-[#777] leading-relaxed mb-6 text-base">
          I'm a project manager who loves crafting meaningful interactions and bringing ideas to life. Based in remote, available worldwide.
        </p>
        <p class="text-[#777] leading-relaxed text-base">
          I design to make people smile.
        </p>
      </div>
      
      <div>
        <h2 class="text-[#333] text-xs font-mono uppercase tracking-widest mb-8">Skills</h2>
        <div class="flex flex-wrap gap-2">
          {Astro.props.skills?.map(skill => (
            <span class="text-[#555] text-sm border border-[#1a1a1a] px-4 py-2 rounded-full">{skill}</span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Contact -->
<section id="contact" class="px-6 md:px-8 py-32 border-t border-[#1a1a1a]">
  <div class="container mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
      <div>
        <h2 class="text-[#333] text-xs font-mono uppercase tracking-widest mb-8">Contact</h2>
        <p class="text-[#777] leading-relaxed mb-8 text-base">
          Have a question or want to work together? Reach out below.
        </p>
        <div class="space-y-4">
          <a href="mailto:bisquery@gmail.com" class="block text-white text-sm hover:text-[#888] transition-colors">
            bisquery@gmail.com
          </a>
          <p class="text-[#555] text-sm">Available Worldwide (Remote)</p>
        </div>
      </div>
      
      <div>
        <h2 class="text-[#333] text-xs font-mono uppercase tracking-widest mb-8">Connect</h2>
        <div class="flex flex-wrap gap-6">
          {Astro.props.socialLinks?.map(link => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="text-[#555] hover:text-white transition-colors text-sm">
              {link.platform}
            </a>
          ))}
        </div>
      </div>
    </div>
    
    <div class="mt-32 pt-8 border-t border-[#1a1a1a]">
      <p class="text-[#222] text-xs font-mono">&copy; {new Date().getFullYear()} anas.</p>
    </div>
  </div>
</section>
