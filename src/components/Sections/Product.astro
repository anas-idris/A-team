---
interface ContactProps {
  contactInfo: {
    email: string;
    phone: string;
  };
  socialLinks?: Array<{
    platform: string;
    url: string;
    icon: 'linkedin' | 'github' | 'twitter';
  }>;
}

const { contactInfo = { email: 'bisquery@gmail.com', phone: '' }, socialLinks } = Astro.props;
---

<!-- Project Portfolio Grid -->
<div class="container mx-auto px-4 sm:px-6 lg:px-8 py-24">
  <h2 class="text-gray-600 text-sm font-mono mb-16">Projects</h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0">
    {[
      {
        title: 'Spent — Expense Tracker',
        description: 'Smart expense tracking with SMS capture, bill scanning, and deep insights. Built with Android Jetpack Compose.',
        year: '2024',
        tags: ['Android', 'Kotlin', 'Jetpack Compose'],
        link: 'https://play.google.com/store/apps/details?id=com.anasidris.spent',
      },
      {
        title: 'Project Delivery Platform',
        description: 'End-to-end project management system with task tracking, resource allocation, and stakeholder dashboards.',
        year: '2024',
        tags: ['Astro', 'Tailwind', 'TypeScript'],
      },
      {
        title: 'Enterprise ERP System',
        description: 'Large-scale ERP implementation across 3 departments with change management and stakeholder alignment.',
        year: '2023',
        tags: ['Enterprise', 'Jira', 'Agile'],
      },
      {
        title: 'Mobile Banking App',
        description: 'Consumer-facing mobile banking platform serving 500K+ users with 99.9% production uptime.',
        year: '2023',
        tags: ['FinTech', 'Android', 'REST API'],
      },
    ].map(project => (
      <a
        href={project.link || '#'}
        target={project.link ? '_blank' : undefined}
        rel={project.link ? 'noopener noreferrer' : undefined}
        class="group py-8 border-t border-[#1a1a1a] hover:opacity-100 transition-opacity"
      >
        <div class="flex items-start justify-between mb-3">
          <h3 class="text-white text-lg font-medium group-hover:text-gray-300 transition-colors">{project.title}</h3>
          <span class="text-gray-600 text-sm font-mono">{project.year}</span>
        </div>
        <p class="text-gray-500 text-sm leading-relaxed mb-4">{project.description}</p>
        <div class="flex flex-wrap gap-2">
          {project.tags.map(tag => (
            <span class="text-xs text-gray-600 font-mono">{tag}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</div>
