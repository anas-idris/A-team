---
interface FooterProps {
  developerName?: string;
  socialLinks?: Array<{
    platform: string;
    url: string;
    icon: 'linkedin';
  }>;
}

const currentYear = new Date().getFullYear();

const {
  developerName = 'Anas',
  socialLinks = [
    { platform: 'LinkedIn', url: 'https://www.linkedin.com/in/anas-idris/', icon: 'linkedin' },
  ],
} = Astro.props;
---

<footer class="bg-professional-primary text-white py-8">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Copyright -->
      <div class="text-professional-primary-light text-body-small">
        <p>&copy; <span client:visible>{currentYear}</span> {developerName}. All rights reserved.</p>
      </div>

      <!-- Social Icons -->
      <div class="flex items-center gap-6">
        {socialLinks.map(link => (
          <a
            href={link.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-professional-primary-light hover:text-professional-accent transition-colors duration-200"
            aria-label={link.platform}
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        ))}
      </div>

      <!-- Back to Top -->
      <a href="#home" class="text-professional-primary-light hover:text-professional-accent transition-colors duration-200 text-body-small" aria-label="Back to top">
        &uarr; Back to top
      </a>
    </div>
  </div>
</footer>
