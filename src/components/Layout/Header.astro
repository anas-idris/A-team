---
interface HeaderProps {
  logo?: string;
  navLinks: Array<{ label: string; href: string }>;
}

const {
  logo = 'Portfolio - Anas Idris',
  navLinks = [
    { label: 'Home', href: '/' },
    { label: 'Work Projects', href: '/work-projects' },
    { label: 'Self Projects', href: '/self-projects' },
    { label: 'Contact', href: '/contact' },
  ],
} = Astro.props;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm shadow-sm">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="text-professional-primary font-heading text-xl font-bold">{logo}</a>

      <nav class="hidden md:flex items-center gap-8" role="navigation" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-professional-text-secondary hover:text-professional-accent transition-colors duration-200 nav-link text-sm font-medium"
            data-nav-link
          >
            {link.label}
          </a>
        ))}
      </nav>

      <button
        class="md:hidden p-3 text-professional-text-primary hover:text-professional-accent active:text-professional-accent z-50"
        aria-label="Open navigation menu"
        aria-expanded="false"
        id="hamburger-btn"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <div
       id="mobile-menu"
       class="hidden md:hidden overflow-hidden transition-all duration-300 ease-in-out"
       style="max-height: 0px; opacity: 0;"
     >
       <nav role="navigation" aria-label="Mobile navigation" class="border-t border-professional-border">
         {navLinks.map(link => (
           <a
             href={link.href}
             class="block py-4 px-4 text-professional-text-secondary hover:text-professional-accent hover:bg-professional-alt-background active:text-professional-accent active:bg-professional-alt-background transition-colors duration-200 nav-link text-sm font-medium"
             data-nav-link
             style="touch-action: manipulation;"
           >
             {link.label}
           </a>
         ))}
       </nav>
     </div>
  </div>
</header>

<script client:visible>
  function initMobileMenu() {
    const hamburger = document.getElementById('hamburger-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    
    if (!hamburger || !mobileMenu) return;

    let isMenuOpen = false;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        mobileMenu.classList.remove('hidden');
        requestAnimationFrame(() => {
          const height = mobileMenu.scrollHeight;
          mobileMenu.style.maxHeight = height + 'px';
          mobileMenu.style.opacity = '1';
          setTimeout(() => {
            if (isMenuOpen && mobileMenu) {
              mobileMenu.style.maxHeight = '';
            }
          }, 300);
        });
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Close navigation menu');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.style.maxHeight = mobileMenu.scrollHeight + 'px';
        requestAnimationFrame(() => {
          mobileMenu.style.maxHeight = '0px';
          mobileMenu.style.opacity = '0';
        });
        setTimeout(() => {
          if (!isMenuOpen && mobileMenu) {
            mobileMenu.classList.add('hidden');
            mobileMenu.style.maxHeight = '';
          }
        }, 300);
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open navigation menu');
        document.body.style.overflow = '';
      }
    }

    hamburger.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    hamburger.addEventListener('touchend', (e) => {
      e.stopPropagation();
      e.preventDefault();
      toggleMenu();
    });

    document.querySelectorAll('[data-nav-link]').forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) {
          toggleMenu();
        }
      });
    });

    document.addEventListener('click', (e) => {
      if (isMenuOpen && !mobileMenu.contains(e.target) && !hamburger.contains(e.target)) {
        toggleMenu();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        toggleMenu();
      }
    });

    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('[data-nav-link]');

    const setActiveLink = (href) => {
      navLinks.forEach(link => {
        const isActive = link.getAttribute('href') === href;
        if (isActive) {
          link.className = 'text-professional-accent font-semibold transition-colors duration-200 nav-link text-sm font-medium';
          link.setAttribute('aria-current', 'page');
        } else {
          link.className = 'text-professional-text-secondary hover:text-professional-accent transition-colors duration-200 nav-link text-sm font-medium';
          link.removeAttribute('aria-current');
        }
      });
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          setActiveLink(id);
        }
      });
    }, { rootMargin: '-30% 0px -70% 0px' });

    sections.forEach(section => observer.observe(section));

    const header = document.querySelector('header');

    window.addEventListener('scroll', () => {
      const currentScroll = window.scrollY;
      if (currentScroll > 100) {
        header?.classList.add('shadow-md');
      } else {
        header?.classList.remove('shadow-md');
      }
    }, { passive: true });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
</script>
