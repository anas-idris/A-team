---
interface BaseLayoutProps {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Anas â€” Project/Product Manager Portfolio | Building & Delivering Digital Products',
  image = '/og-image.png',
} = Astro.props;

import '../../styles/globals.css';

const siteUrl = import.meta.env.SITE || 'https://example.com';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Anas Idris',
  jobTitle: 'Project/Product Manager',
  url: siteUrl,
  sameAs: [
    'https://www.linkedin.com/in/anas-idris/',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Anas â€” Project Portfolio',
  url: siteUrl,
};
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Anas Idris</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${image}`} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${image}`} />

    <meta name="robots" content="index, follow" />

    <script type="application/ld+json">{JSON.stringify(personSchema)}</script>
    <script type="application/ld+json">{JSON.stringify(websiteSchema)}</script>

    {import.meta.env.PLAUSIBLE_DOMAIN && (
      <script
        defer
        data-domain={import.meta.env.PLAUSIBLE_DOMAIN}
        src="https://plausible.io/js/script.js"
      ></script>
    )}

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #f8f9fa;
        color: #2c3e50;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px;
      }

      @media (min-width: 768px) {
        .container {
          padding: 0 48px;
        }
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: #f1f1f1;
      }

      ::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 4px;
      }

      ::selection {
        background: #3498db;
        color: #fff;
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="sr-only">Skip to content</a>
    
    <main id="main-content" role="main">
      <slot />
    </main>
  </body>
</html>
